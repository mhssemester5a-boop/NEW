// ===== CHARTS & VISUALISASI DATA =====
function renderCharts() {
  const sumKas = santriData.reduce((a,c)=>a+Number(c.nominalKas||0),0);
  const sumInfaq = santriData.reduce((a,c)=>a+Number(c.nominalInfaq||0),0);
  const totalKeluar = expensesData.reduce((a,c)=>a+Number(c.nominal||0),0);
  const totalMasuk = sumKas + sumInfaq;

  if(pieChart) pieChart.destroy();
  const ctxPie = document.getElementById('chartPie').getContext('2d');
  pieChart = new Chart(ctxPie, {
    type:'doughnut',
    data:{
      labels:['Pemasukan','Pengeluaran'],
      datasets:[{data:[totalMasuk, totalKeluar], backgroundColor:['#005C41','#f43f5e'], borderWidth:0}]
    },
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'bottom',labels:{font:{size:10,family:'"Plus Jakarta Sans"'},padding:10}}}}
  });

  const chartType = document.getElementById('chartSelector') ? document.getElementById('chartSelector').value : 'bulan';
  if(barChart) barChart.destroy();
  const ctxBar = document.getElementById('chartBar').getContext('2d');

  if (chartType === 'bulan') {
    const months = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];
    const kasPerBulan = Array(12).fill(0);
    santriData.forEach(s => {
      if(s.tanggal) { const m = new Date(s.tanggal+'T00:00:00').getMonth(); kasPerBulan[m] += Number(s.nominalKas||0)+Number(s.nominalInfaq||0); }
    });
    barChart = new Chart(ctxBar, {
      type:'bar',
      data:{
        labels:months,
        datasets:[{label:'Kas + Infaq',data:kasPerBulan,backgroundColor:'rgba(0,92,65,0.75)',borderRadius:6}]
      },
      options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true,ticks:{font:{size:9,family:'"Plus Jakarta Sans"'},callback:v=>v>=1000?'Rp'+(v/1000)+'k':'Rp'+v},grid:{color:'rgba(0,0,0,0.04)'}},x:{ticks:{font:{size:9,family:'"Plus Jakarta Sans"'}}}}}
    });
  } else if (chartType === 'kelompok') {
    const groups = [...new Set(membersData.map(m=>m.kelompok))];
    const kasPerKelompok = Array(groups.length).fill(0);
    santriData.forEach(s => {
      const member = membersData.find(m => m.nama.toUpperCase() === s.nama.toUpperCase());
      if(member) {
        const gIdx = groups.indexOf(member.kelompok);
        if(gIdx !== -1) {
          kasPerKelompok[gIdx] += Number(s.nominalKas||0)+Number(s.nominalInfaq||0);
        }
      }
    });
    barChart = new Chart(ctxBar, {
      type:'bar',
      data:{
        labels:groups.map(g => g.replace('Kelas ','')), 
        datasets:[{label:'Total Pemasukan',data:kasPerKelompok,backgroundColor:'rgba(197,160,89,0.75)',borderRadius:6}]
      },
      options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true,ticks:{font:{size:9,family:'"Plus Jakarta Sans"'},callback:v=>v>=1000?'Rp'+(v/1000)+'k':'Rp'+v},grid:{color:'rgba(0,0,0,0.04)'}},x:{ticks:{font:{size:8,family:'"Plus Jakarta Sans"'}}}}}
    });
  } else if (chartType === 'status') {
    let cLunas=0, cKurang=0, cBelum=0;
    membersData.forEach(member => {
      const st = getStatusSantri(member).status;
      if(st==='lunas') cLunas++;
      else if(st==='kurang') cKurang++;
      else cBelum++;
    });
    barChart = new Chart(ctxBar, {
      type:'doughnut',
      data:{
        labels:['Lunas', 'Kurang', 'Belum Bayar'],
        datasets:[{data:[cLunas, cKurang, cBelum], backgroundColor:['#005C41','#C5A059','#f43f5e'], borderWidth:0}]
      },
      options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'bottom',labels:{font:{size:10,family:'"Plus Jakarta Sans"'},padding:10}}}}
    });
  }
}

