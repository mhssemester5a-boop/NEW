// ===== FORMATTERS & LOGGER =====
function fRp(n) { return new Intl.NumberFormat('id-ID',{style:'currency',currency:'IDR',minimumFractionDigits:0}).format(n||0); }
function fTgl(d) { if(!d)return"-"; return new Date(d+'T00:00:00').toLocaleDateString('id-ID',{day:'numeric',month:'short',year:'numeric'}); }
function addLog(msg) {
  const now = new Date().toLocaleString('id-ID');
  activityLog.unshift({waktu:now, pesan:msg});
  if(activityLog.length>100) activityLog.pop();
  saveAll();
}

function getStatusSantri(member) {
  const nama = member.nama.toUpperCase();
  const setor = santriData.filter(s => s.nama.toUpperCase() === nama);
  if (setor.length === 0) return {status:'belum', totalKas:0, totalInfaq:0, lastTanggal:null, jatuhTempo:null};
  const totalKas = setor.reduce((a,c)=>a+Number(c.nominalKas||0),0);
  const totalInfaq = setor.reduce((a,c)=>a+Number(c.nominalInfaq||0),0);
  const lastRecord = setor.sort((a,b)=>new Date(b.tanggal)-new Date(a.tanggal))[0];
  let jatuhTempo = null;
  if(lastRecord) {
    const tglBayar = new Date(lastRecord.tanggal+'T00:00:00');
    const tahun = Number(lastRecord.tahun||1);
    jatuhTempo = new Date(tglBayar);
    jatuhTempo.setFullYear(jatuhTempo.getFullYear()+tahun);
  }
  const KAS_TARGET = 50000;
  let status = 'lunas';
  if(totalKas < KAS_TARGET) status = 'kurang';
  return {status, totalKas, totalInfaq, lastTanggal: lastRecord?.tanggal, jatuhTempo};
}

function getBadgeHtml(status) {
  if(status==='lunas') return `<span class="badge-lunas text-[9px] font-bold px-2.5 py-1 rounded-full">✅ Lunas</span>`;
  if(status==='kurang') return `<span class="badge-kurang text-[9px] font-bold px-2.5 py-1 rounded-full">⚠️ Kurang</span>`;
  if(status==='belum') return `<span class="badge-belum text-[9px] font-bold px-2.5 py-1 rounded-full">❌ Belum</span>`;
  if(status==='jatuh') return `<span class="badge-jatuh text-[9px] font-bold px-2.5 py-1 rounded-full">🔔 Jatuh Tempo</span>`;
  return '';
}

