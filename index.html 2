// ===== DATABASE BACKUP, RESTORE & EXPORTS =====
function downloadCSV() {
  let csv = "Nama,Kelompok,Tanggal,Kas,Tahun,Infaq,Keterangan,Total\r\n";
  santriData.forEach(s => {
    const m = membersData.find(mb=>mb.nama.toUpperCase()===s.nama.toUpperCase());
    csv += `"${s.nama}","${m?m.kelompok:'-'}","${s.tanggal}",${s.nominalKas},${s.tahun||1},${s.nominalInfaq},"${s.keteranganLain||''}",${Number(s.nominalKas)+Number(s.nominalInfaq)}\r\n`;
  });
  const a = document.createElement('a');
  a.href = 'data:text/csv;charset=utf-8,'+encodeURIComponent(csv);
  a.download = `Rekap_J2_${new Date().toISOString().slice(0,10)}.csv`;
  a.click();
  showToast("CSV berhasil diunduh!","download");
  addLog("Ekspor laporan CSV.");
}
function downloadJSONBackup() {
  const data = JSON.stringify({santri:santriData, expenses:expensesData, members:membersData, backupDate:new Date()});
  const a = document.createElement('a');
  a.href = 'data:text/json;charset=utf-8,'+encodeURIComponent(data);
  a.download = `Backup_J2_${new Date().toISOString().slice(0,10)}.json`;
  a.click();
  showToast("Backup JSON diunduh!","database");
  addLog("Backup data JSON diunduh.");
}
function importJSONBackup(e) {
  const file = e.target.files[0]; if(!file) return;
  const reader = new FileReader();
  reader.onload = function(ev) {
    try {
      const data = JSON.parse(ev.target.result);
      if(data.santri && data.expenses) {
        openCustomConfirm("Restore Backup","Tumpuk data saat ini dengan backup ini?", ()=>{
          santriData = data.santri;
          expensesData = data.expenses;
          if(data.members) membersData = data.members;
          saveAll(); renderAll();
          showToast("Berhasil di-restore!","upload-cloud");
          addLog("Restore backup JSON berhasil.");
        });
      }
    } catch(err) { showToast("Format JSON salah!","alert-triangle"); }
  };
  reader.readAsText(file); e.target.value='';
}

// ===== DIALOG KONFIRMASI KUSTOM =====
function openCustomConfirm(title, msg, cb) {
  document.getElementById('confirmTitle').textContent = title;
  document.getElementById('confirmMessage').textContent = msg;
  document.getElementById('confirmModal').classList.remove('hidden');
  confirmActionCallback = cb;
}
document.getElementById('btnConfirmOK').addEventListener('click', ()=>{
  document.getElementById('confirmModal').classList.add('hidden');
  if(confirmActionCallback){ confirmActionCallback(); confirmActionCallback=null; }
});
document.getElementById('btnConfirmCancel').addEventListener('click', ()=>{
  document.getElementById('confirmModal').classList.add('hidden'); confirmActionCallback=null;
});

// ===== NOTIFIKASI TOAST =====
function showToast(msg, icon='check-circle') {
  const toast = document.getElementById('toastNotification');
  document.getElementById('toastMessage').textContent = msg;
  document.getElementById('toastIcon').innerHTML = `<i data-lucide="${icon}" class="h-4 w-4"></i>`;
  lucide.createIcons();
  toast.classList.remove('translate-y-24','opacity-0');
  toast.classList.add('translate-y-0','opacity-100');
  setTimeout(()=>{ toast.classList.remove('translate-y-0','opacity-100'); toast.classList.add('translate-y-24','opacity-0'); }, 3000);
}

// ===== PANDUAN SUARA INTELLIGENT =====
function playVoiceGuide() {
  if(!('speechSynthesis' in window)) { showToast("Browser tidak mendukung fitur suara.","alert-triangle"); return; }
  if(isSpeaking) { window.speechSynthesis.cancel(); isSpeaking=false; return; }
  const speech = new SpeechSynthesisUtterance("Selamat datang di Portal SmartKas Kamar J2 Pondok Pesantren Al-Iman Bulus. Ketik nama santri pada kolom pencarian untuk melihat status pembayaran. Anda dapat mencetak kuitansi dengan menekan tombol cetak di setiap baris.");
  speech.lang='id-ID'; speech.rate=0.9;
  speech.onstart=()=>{ isSpeaking=true; };
  speech.onend=()=>{ isSpeaking=false; };
  window.speechSynthesis.speak(speech);
}
</script>
