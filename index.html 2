<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>J2 SmartKas - Ponpes Al-Iman Bulus (BSI Style)</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://unpkg.com/lucide@latest"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<!-- Menggunakan Montserrat (Fintech Header) + Plus Jakarta Sans (Clean Body) + Amiri (Islamic Arabic) -->
<link href="https://fonts.googleapis.com/css2?family=Amiri:ital,wght@0,400;0,700;1,400;1,700&family=Montserrat:wght@300;400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
body { 
  font-family: 'Plus Jakarta Sans', sans-serif; 
  background: #F4F7F5; /* Latar belakang bersih khas BSI */
  letter-spacing: -0.01em;
}
.font-montserrat { 
  font-family: 'Montserrat', sans-serif; 
}
/* Warna Hijau Premium khas BSI */
.bsi-green-dark {
  background-color: #003B2A;
}
.bsi-green-brand {
  background-color: #005C41;
}
.text-bsi-green {
  color: #005C41;
}
.border-bsi-green {
  border-color: #005C41;
}
/* Aksen Emas BSI */
.text-bsi-gold { 
  color: #C5A059; 
}
.bg-bsi-gold {
  background-color: #C5A059;
}
.bg-bsi-gold-gradient {
  background: linear-gradient(135deg, #DFBA73 0%, #C5A059 100%);
}
.text-bsi-gold-gradient {
  background: linear-gradient(135deg, #DFBA73 0%, #C5A059 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}
/* Latar Belakang Landing Page Elegan */
.bsi-landing-bg { 
  background-color: #003625; 
  background-image: radial-gradient(at 0% 0%, #005C41 0px, transparent 55%), radial-gradient(at 100% 100%, #002216 0px, transparent 60%); 
}
.glass-card-bsi { 
  background: rgba(255, 255, 255, 0.03); 
  backdrop-filter: blur(20px); 
  border: 1px solid rgba(255, 255, 255, 0.08); 
  box-shadow: 0 12px 40px -12px rgba(0,0,0,0.4); 
}
.arabic-font { 
  font-family: 'Amiri', serif; 
  line-height: 1.8;
}
::-webkit-scrollbar { 
  width: 6px; 
  height: 6px; 
}
::-webkit-scrollbar-track { 
  background: #f1f5f9; 
}
::-webkit-scrollbar-thumb { 
  background: #cbd5e1; 
  border-radius: 6px; 
}
.glass-card { 
  background: rgba(255, 255, 255, 0.95); 
  backdrop-filter: blur(12px); 
  border: 1px solid rgba(255, 255, 255, 0.8); 
  box-shadow: 0 10px 30px -10px rgba(0,80,60,0.04); 
}
.fade-in { 
  animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; 
}
@keyframes fadeIn { 
  from { opacity: 0; transform: translateY(15px); } 
  to { opacity: 1; transform: translateY(0); } 
}
.badge-lunas { background: #e6fbf1; color: #005C41; }
.badge-kurang { background: #fffbeb; color: #b45309; }
.badge-belum { background: #fef2f2; color: #b91c1c; }
.badge-jatuh { background: #fdf2f8; color: #be185d; }
.dark-overlay { background: rgba(0, 20, 15, 0.6); }

@media print { 
  body * { visibility: hidden; } 
  #receiptPrintArea, #receiptPrintArea * { visibility: visible; } 
  #receiptPrintArea { position: absolute; left: 0; top: 0; width: 100%; background: white; color: black; } 
}
@media(max-width:640px){
  .mobile-card-view { display: block !important; }
  .desktop-table { display: none !important; }
}
</style>
</head>
<body class="min-h-screen text-slate-800 antialiased">

<!-- ===== LANDING PAGE ===== -->
<div id="landingPage" class="fixed inset-0 z-50 bsi-landing-bg flex flex-col justify-between overflow-y-auto">
  <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-[#005C41]/20 rounded-full blur-[130px] pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-[#C5A059]/10 rounded-full blur-[120px] pointer-events-none"></div>

  <!-- Header Landing -->
  <div class="max-w-6xl mx-auto w-full px-6 pt-8 flex justify-between items-center z-10 fade-in">
    <div class="flex items-center space-x-3.5">
      <div class="bg-gradient-to-br from-[#005C41] to-[#003B2A] border border-white/10 p-3 rounded-2xl shadow-xl">
        <i data-lucide="mosque" class="h-6 w-6 text-bsi-gold"></i>
      </div>
      <div>
        <span class="text-[9px] text-bsi-gold font-bold uppercase tracking-[0.2em] block mb-0.5">Layanan Kas Mandiri</span>
        <h2 class="text-white font-montserrat font-bold text-2xl tracking-tight leading-none">J2 <span class="text-bsi-gold">SmartKas</span></h2>
      </div>
    </div>
    <button onclick="playVoiceGuide()" id="btnVoiceLanding" class="hidden md:flex items-center space-x-2.5 text-xs font-semibold text-white/95 border border-white/15 px-5 py-2.5 rounded-full hover:bg-white/10 transition duration-300 backdrop-blur-sm">
      <i data-lucide="volume-2" class="h-4 w-4 text-bsi-gold"></i><span>Panduan Suara</span>
    </button>
  </div>

  <!-- Konten Utama Landing -->
  <div class="max-w-6xl mx-auto w-full px-6 py-12 z-10 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
    <div class="lg:col-span-6 space-y-8 fade-in">
      <span class="inline-flex items-center space-x-2 bg-white/5 border border-white/10 text-white/90 text-[10px] px-4 py-2 rounded-full font-bold uppercase tracking-[0.15em] backdrop-blur-sm">
        <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
        <span>Ponpes Al-Iman Bulus</span>
      </span>
      <div class="space-y-4">
        <h1 class="text-5xl md:text-6xl font-montserrat font-extrabold text-white tracking-tight leading-[1.1]">
          Sistem Kas & Infaq<br><span class="italic text-bsi-gold-gradient font-normal font-serif">Kamar J2</span>
        </h1>
        <p class="text-sm md:text-base text-white/60 font-light leading-relaxed max-w-md">
          Daerah Gebang-Loano · <span class="text-bsi-gold font-semibold">Khusus Putra</span> · Pengelolaan keuangan syariah transparan, aman, dan akuntabel.
        </p>
      </div>
      
      <!-- Kutipan Ayat Islami -->
      <div class="glass-card-bsi rounded-2xl p-6 border-l-[3px] border-l-bsi-gold relative overflow-hidden">
        <div class="absolute top-0 right-0 p-4 opacity-5"><i data-lucide="quote" class="h-12 w-12 text-bsi-gold"></i></div>
        <div class="flex items-center space-x-2 text-bsi-gold text-[10px] font-bold uppercase tracking-[0.15em] mb-4">
          <i data-lucide="book-open" class="h-3.5 w-3.5"></i><span>Keutamaan Berinfaq</span>
        </div>
        <div class="arabic-font text-xl md:text-2xl text-white leading-loose mb-3 text-right font-medium">مَّثَلُ ٱلَّذِينَ يُنفِقُونَ أَمْوَٰلَهُمْ فِى سَبِيلِ ٱللَّهِ كَمَثَلِ حَبَّةٍ أَنبَتَتْ سَبْعَ سَنَابِلَ</div>
        <p class="text-[11px] md:text-xs text-white/50 italic border-t border-white/10 pt-3 leading-relaxed">
          "Perumpamaan orang yang menginfakkan hartanya di jalan Allah seperti sebutir biji yang menumbuhkan tujuh tangkai..."
        </p>
        <span class="text-[10px] text-bsi-gold font-semibold block mt-2">— QS. Al-Baqarah : 261</span>
      </div>
    </div>

    <!-- Pilihan Portal -->
    <div class="lg:col-span-6 space-y-5 fade-in">
      <p class="text-xs text-white/40 font-bold uppercase tracking-[0.2em] text-center lg:text-left">Pilih Layanan Portal:</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Portal Wali -->
        <div onclick="enterAsWali()" class="group glass-card-bsi hover:bg-white/10 rounded-3xl p-8 transition-all duration-500 cursor-pointer border border-white/10 hover:border-[#005C41]/50 shadow-2xl">
          <div class="bg-[#005C41] border border-white/10 p-4 rounded-2xl text-bsi-gold inline-block mb-6 group-hover:scale-110 transition-transform duration-500 shadow-md">
            <i data-lucide="users" class="h-6 w-6"></i>
          </div>
          <h4 class="text-bsi-gold text-[10px] font-bold uppercase tracking-[0.15em]">Layanan Wali Santri</h4>
          <h3 class="text-white font-montserrat text-2xl font-bold mt-1 tracking-tight">Portal Wali</h3>
          <p class="text-white/50 text-xs leading-relaxed mt-4 pt-4 border-t border-white/10 font-light">
            Pantau rincian pembayaran, status kelunasan bulanan, dan cetak kuitansi digital secara instan.
          </p>
          <div class="mt-6 flex justify-between items-center text-[11px] font-bold tracking-wider text-bsi-gold">
            <span>MASUK PORTAL</span><i data-lucide="arrow-right" class="h-4 w-4 group-hover:translate-x-1.5 transition-transform duration-500"></i>
          </div>
        </div>
        
        <!-- Portal Pengurus -->
        <div onclick="openAdminAuth()" class="group glass-card-bsi hover:bg-white/10 rounded-3xl p-8 transition-all duration-500 cursor-pointer border border-white/10 hover:border-[#005C41]/50 relative overflow-hidden shadow-2xl">
          <div class="bg-[#005C41] border border-white/10 p-4 rounded-2xl text-bsi-gold inline-block mb-6 group-hover:scale-110 transition-transform duration-500 shadow-md">
            <i data-lucide="shield-check" class="h-6 w-6"></i>
          </div>
          <h4 class="text-bsi-gold text-[10px] font-bold uppercase tracking-[0.15em]">Layanan Manajemen</h4>
          <h3 class="text-white font-montserrat text-2xl font-bold mt-1 tracking-tight">Pengurus J2</h3>
          <p class="text-white/50 text-xs leading-relaxed mt-4 pt-4 border-t border-white/10 font-light">
            Kelola setoran uang kas, rincian pengeluaran, data anggota kamar, serta ekspor-impor database.
          </p>
          <div class="mt-6 flex justify-between items-center text-[11px] font-bold tracking-wider text-bsi-gold">
            <span>OTENTIKASI AMAN</span>
            <div class="flex items-center space-x-1.5"><i data-lucide="lock" class="h-3 w-3"></i><span class="text-[10px] uppercase font-bold">PIN</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer Landing -->
  <div class="w-full border-t border-white/10 py-5 z-10 bg-[#002216]/80 backdrop-blur-md">
    <p class="text-center text-[10px] text-white/40 font-semibold tracking-[0.15em]">&copy; 2026 Ponpes Al-Iman Bulus Purworejo · Kamar J2 Gebang-Loano</p>
  </div>
</div>

<!-- ===== MAIN APP ===== -->
<div id="mainApp" class="hidden flex-col min-h-screen">
  <!-- Navigasi Utama ala BSI Modern -->
  <header class="bg-white border-b border-slate-100 sticky top-0 z-40 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex justify-between items-center py-4">
        <div class="flex items-center space-x-3.5">
          <div class="bg-[#005C41] p-2.5 rounded-xl shadow-sm">
            <i data-lucide="mosque" class="h-5 w-5 text-bsi-gold"></i>
          </div>
          <div>
            <h1 class="text-lg font-montserrat font-extrabold tracking-tight text-[#003B2A]">J2 <span class="text-bsi-gold">SmartKas</span></h1>
            <p class="text-[9px] text-emerald-750 uppercase tracking-[0.18em] font-extrabold">Pondok Pesantren Al-Iman Bulus</p>
          </div>
        </div>
        
        <!-- Pemilih Role Navigasi -->
        <div class="flex items-center space-x-1.5">
          <button onclick="backToLanding()" class="p-2 text-slate-400 hover:text-[#005C41] rounded-xl hover:bg-slate-50 transition" title="Beranda">
            <i data-lucide="home" class="h-4.5 w-4.5"></i>
          </button>
          <div class="h-5 w-px bg-slate-200 mx-1"></div>
          <button id="btnRoleWali" onclick="switchRole('wali')" class="flex items-center space-x-1.5 px-3 py-2 rounded-xl text-xs font-bold bg-[#e6fbf1] text-[#005C41] border border-emerald-100 shadow-sm transition">
            <i data-lucide="users" class="h-3.5 w-3.5"></i><span class="hidden sm:inline">Wali Santri</span>
          </button>
          <button id="btnRoleAdmin" onclick="openAdminAuth()" class="flex items-center space-x-1.5 px-3 py-2 rounded-xl text-xs font-bold text-slate-500 hover:bg-slate-50 hover:text-slate-800 border border-transparent transition">
            <i data-lucide="shield-check" class="h-3.5 w-3.5"></i><span class="hidden sm:inline">Admin J2</span>
          </button>
        </div>
      </div>
    </div>
  </header>

  <!-- Kontainer Konten Utama -->
  <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 py-8">

    <!-- ===== WALI SANTRI PORTAL ===== -->
    <section id="waliPortal" class="space-y-6">
      <div class="bg-white rounded-3xl p-8 text-center border-t-4 border-t-[#005C41] shadow-sm relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-b from-[#005C41]/5 to-transparent pointer-events-none opacity-40"></div>
        <div class="arabic-font text-3xl text-[#005C41] mb-3 font-semibold">بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ</div>
        <h2 class="text-3xl font-montserrat font-bold text-slate-850 tracking-tight">Transparansi Finansial Kamar J2</h2>
        <p class="text-sm text-slate-500 mt-2.5 max-w-xl mx-auto font-light leading-relaxed">
          Selamat datang para Wali Santri. Pantau rekapitulasi iuran kas bulanan dan pengeluaran operasional kamar secara terbuka & *real-time*.
        </p>
      </div>

      <!-- Jatuh Tempo Alert -->
      <div id="alertJatuhTempo" class="hidden bg-pink-50 border border-pink-100 rounded-2xl p-4 text-xs text-pink-900">
        <div class="flex items-center gap-2 font-bold mb-1.5"><i data-lucide="bell" class="h-4 w-4 text-pink-600 animate-bounce"></i> Pemberitahuan Jatuh Tempo:</div>
        <ul id="alertList" class="space-y-1 ml-6 list-disc"></ul>
      </div>

      <!-- Baris Statistik Utama (Fintech Cards) -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div class="bg-white rounded-2xl border border-slate-100 p-5 shadow-[0_8px_30px_rgb(0,0,0,0.015)] hover:shadow-md transition duration-300">
          <div class="text-[10px] text-slate-400 uppercase font-bold tracking-wider">Total Anggota</div>
          <div id="wStatAnggota" class="text-2xl font-extrabold text-[#003B2A] mt-1">-</div>
        </div>
        <div class="bg-white rounded-2xl border border-slate-100 p-5 shadow-[0_8px_30px_rgb(0,0,0,0.015)] hover:shadow-md transition duration-300">
          <div class="text-[10px] text-[#005C41] uppercase font-bold tracking-wider">Sudah Lunas</div>
          <div id="wStatLunas" class="text-2xl font-extrabold text-[#005C41] mt-1">-</div>
        </div>
        <div class="bg-white rounded-2xl border border-slate-100 p-5 shadow-[0_8px_30px_rgb(0,0,0,0.015)] hover:shadow-md transition duration-300">
          <div class="text-[10px] text-amber-600 uppercase font-bold tracking-wider">Kurang Bayar</div>
          <div id="wStatKurang" class="text-2xl font-extrabold text-amber-600 mt-1">-</div>
        </div>
        <div class="bg-white rounded-2xl border border-slate-100 p-5 shadow-[0_8px_30px_rgb(0,0,0,0.015)] hover:shadow-md transition duration-300">
          <div class="text-[10px] text-rose-600 uppercase font-bold tracking-wider">Belum Bayar</div>
          <div id="wStatBelum" class="text-2xl font-extrabold text-rose-600 mt-1">-</div>
        </div>
      </div>

      <!-- Modul Charts / Visualisasi Data -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm lg:col-span-5">
          <h4 class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-5">Pemasukan vs Pengeluaran</h4>
          <div style="height:220px;" class="relative"><canvas id="chartPie"></canvas></div>
        </div>
        <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm lg:col-span-7">
          <div class="flex justify-between items-center mb-5">
            <h4 class="text-xs font-bold text-slate-500 uppercase tracking-wider">Statistik Detail</h4>
            <select id="chartSelector" onchange="renderCharts()" class="text-[10px] font-bold border border-slate-200 text-slate-600 rounded-xl px-3 py-2 bg-slate-50 hover:bg-slate-100 transition focus:ring-1 focus:ring-[#005C41] outline-none cursor-pointer">
              <option value="bulan">Kas per Bulan</option>
              <option value="kelompok">Kas per Kelompok</option>
              <option value="status">Status Pembayaran</option>
            </select>
          </div>
          <div style="height:220px;" class="relative"><canvas id="chartBar"></canvas></div>
        </div>
      </div>

      <!-- Modul Pencarian & Filter Data -->
      <div class="bg-white rounded-3xl border border-slate-100 p-6 shadow-sm">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 items-end">
          <div class="sm:col-span-1">
            <label class="block text-xs font-bold text-slate-600 mb-1.5 uppercase tracking-wide">Cari Nama Santri:</label>
            <div class="relative">
              <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center text-slate-400"><i data-lucide="search" class="h-4.5 w-4.5"></i></span>
              <input type="text" id="searchSantri" oninput="renderWaliTable()" placeholder="Ketik nama santri..." class="w-full pl-10 pr-4 py-3 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-[#005C41] focus:border-[#005C41] bg-slate-50/50">
            </div>
          </div>
          <div>
            <label class="block text-xs font-bold text-slate-600 mb-1.5 uppercase tracking-wide">Filter Status:</label>
            <select id="filterStatus" onchange="renderWaliTable()" class="w-full px-4 py-3 border border-slate-200 rounded-xl text-sm bg-slate-50/50 focus:ring-2 focus:ring-[#005C41] focus:border-[#005C41] font-medium">
              <option value="">Semua Status</option>
              <option value="lunas">✅ Lunas</option>
              <option value="kurang">⚠️ Kurang Bayar</option>
              <option value="belum">❌ Belum Bayar</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-bold text-slate-600 mb-1.5 uppercase tracking-wide">Filter Periode:</label>
            <div class="flex gap-2">
              <select id="filterBulan" onchange="renderWaliTable()" class="flex-1 px-3 py-3 border border-slate-200 rounded-xl text-sm bg-slate-50/50 focus:ring-2 focus:ring-[#005C41] focus:border-[#005C41] font-medium">
                <option value="">Semua Bulan</option>
                <option value="1">Januari</option><option value="2">Februari</option><option value="3">Maret</option>
                <option value="4">April</option><option value="5">Mei</option><option value="6">Juni</option>
                <option value="7">Juli</option><option value="8">Agustus</option><option value="9">September</option>
                <option value="10">Oktober</option><option value="11">November</option><option value="12">Desember</option>
              </select>
              <select id="filterTahun" onchange="renderWaliTable()" class="flex-1 px-3 py-3 border border-slate-200 rounded-xl text-sm bg-slate-50/50 focus:ring-2 focus:ring-[#005C41] focus:border-[#005C41] font-medium">
                <option value="">Semua Tahun</option>
                <option value="2024">2024</option><option value="2025">2025</option><option value="2026">2026</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <!-- Tabel Data Rekapitulasi Wali -->
      <div class="bg-white rounded-3xl border border-slate-100 overflow-hidden shadow-sm">
        <div class="px-6 py-5 border-b border-slate-100 bg-slate-50/50 flex justify-between items-center">
          <h3 class="text-sm font-bold text-slate-800 flex items-center gap-2">
            <i data-lucide="list" class="h-4.5 w-4.5 text-[#005C41]"></i> Rekap Anggota Kamar J2
          </h3>
          <span id="waliCountLabel" class="bg-white text-[#005C41] text-xs px-4 py-1.5 rounded-full font-bold border border-emerald-100 shadow-sm">-</span>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr class="bg-white text-slate-450 uppercase text-[10px] font-bold tracking-wider border-b border-slate-100">
                <th class="py-4 px-6">Nama Santri</th>
                <th class="py-4 px-6 hidden sm:table-cell">Kelompok</th>
                <th class="py-4 px-6 text-center">Status</th>
                <th class="py-4 px-6 text-right hidden md:table-cell">Kas</th>
                <th class="py-4 px-6 text-right hidden md:table-cell">Infaq</th>
                <th class="py-4 px-6 text-right font-bold text-slate-600">Total</th>
                <th class="py-4 px-6 text-center">Aksi</th>
              </tr>
            </thead>
            <tbody id="waliTableBody" class="divide-y divide-slate-50 text-sm"></tbody>
          </table>
        </div>
        <div id="waliEmptyState" class="hidden py-14 text-center">
          <i data-lucide="inbox" class="h-10 w-10 mx-auto text-slate-300 mb-3"></i>
          <p class="text-slate-500 text-sm font-medium">Data tidak ditemukan.</p>
        </div>
      </div>
    </section>

    <!-- ===== ADMIN PORTAL ===== -->
    <section id="adminPortal" class="hidden space-y-6">
      <div class="bg-amber-50 border border-amber-200 rounded-2xl p-4 text-xs text-amber-900 flex items-center gap-2.5 shadow-sm">
        <i data-lucide="shield" class="h-5 w-5 text-amber-600 flex-shrink-0"></i>
        <span><strong>Mode Pengurus Aktif</strong> — Seluruh pengeditan data akan otomatis diperbarui dan disinkronkan ke halaman utama Wali Santri.</span>
      </div>

      <!-- Panel Informasi Finansial Admin -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-white p-5 rounded-2xl border border-slate-100 shadow-sm">
