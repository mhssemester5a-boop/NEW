// ===== PORTAL WALI: DATATABLE =====
function renderWaliTable() {
  const search = document.getElementById('searchSantri').value.toLowerCase().trim();
  const filterSt = document.getElementById('filterStatus').value;
  const filterBl = document.getElementById('filterBulan').value;
  const filterTh = document.getElementById('filterTahun').value;
  const tbody = document.getElementById('waliTableBody');
  tbody.innerHTML = '';

  let countLunas=0, countKurang=0, countBelum=0;
  const today = new Date();
  const alertList = document.getElementById('alertList');
  alertList.innerHTML = '';
  let hasAlert = false;

  let rows = [];
  membersData.forEach(member => {
    if(search && !member.nama.toLowerCase().includes(search)) return;
    const st = getStatusSantri(member);
    if(filterSt && st.status !== filterSt) return;

    if(filterBl || filterTh) {
      const setor = santriData.filter(s=>s.nama.toUpperCase()===member.nama.toUpperCase());
      const match = setor.some(s => {
        if(!s.tanggal) return false;
        const d = new Date(s.tanggal+'T00:00:00');
        const bl = filterBl ? d.getMonth()+1 === parseInt(filterBl) : true;
        const th = filterTh ? d.getFullYear() === parseInt(filterTh) : true;
        return bl && th;
      });
      if(!match) return;
    }

    if(st.status==='lunas') countLunas++;
    else if(st.status==='kurang') countKurang++;
    else countBelum++;

    let displayStatus = st.status;
    if(st.jatuhTempo) {
      const diff = (st.jatuhTempo - today) / (1000*60*60*24);
      if(diff <= 30 && diff >= 0) {
        hasAlert = true;
        alertList.innerHTML += `<li>${member.nama} — jatuh tempo ${fTgl(st.jatuhTempo.toISOString().slice(0,10))} (${Math.round(diff)} hari lagi)</li>`;
        displayStatus = 'jatuh';
      } else if(diff < 0 && st.status === 'lunas') {
        hasAlert = true;
        alertList.innerHTML += `<li class="text-rose-800">${member.nama} — <b>sudah lewat jatuh tempo</b> (${fTgl(st.jatuhTempo.toISOString().slice(0,10))})</li>`;
        displayStatus = 'jatuh';
      }
    }

    rows.push({member, st, displayStatus});
  });

  document.getElementById('alertJatuhTempo').classList.toggle('hidden', !hasAlert);
  document.getElementById('wStatAnggota').textContent = membersData.length;
  document.getElementById('wStatLunas').textContent = countLunas;
  document.getElementById('wStatKurang').textContent = countKurang;
  document.getElementById('wStatBelum').textContent = membersData.length - countLunas - countKurang;
  document.getElementById('waliCountLabel').textContent = rows.length + ' Anggota';

  if(rows.length === 0) {
    document.getElementById('waliEmptyState').classList.remove('hidden');
  } else {
    document.getElementById('waliEmptyState').classList.add('hidden');
    rows.forEach(({member, st, displayStatus}) => {
      const realIdx = santriData.findIndex(s=>s.nama.toUpperCase()===member.nama.toUpperCase());
      const tr = document.createElement('tr');
      tr.className = 'hover:bg-slate-50 transition';
      tr.innerHTML = `
        <td class="py-4 px-6 font-semibold text-slate-850 text-sm capitalize">${member.nama}</td>
        <td class="py-4 px-6 text-slate-400 text-xs hidden sm:table-cell font-medium">${member.kelompok}</td>
